// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enumeraciones ────────────────────────────────────────────────────────────

enum Role {
  super_admin
  admin
  driver
  client
}

enum UserStatus {
  active
  inactive
  suspended
}

enum TransportType {
  on_foot
  bike
  motorcycle
  car
}

enum Urgency {
  baja
  media
  alta
}

enum DeletionReason {
  PRIVACY_CONCERNS
  APP_NOT_USEFUL
  TOO_MANY_NOTIFICATIONS
  TEMPORARY_ACC_CREATION
  OTHER
}

// ─── Ciudades ─────────────────────────────────────────────────────────────────

model City {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  country     String   @default("Bolivia")
  currency    String   @default("BOB") @db.VarChar(3)
  timezone    String   @default("America/La_Paz")
  is_active   Boolean  @default(true)
  center_lat  Float    @default(-17.9647)
  center_lng  Float    @default(-67.1060)
  coordinates Unsupported("geometry(Geometry, 4326)")?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  orders Order[]

  @@map("cities")
}

// ─── Usuarios ─────────────────────────────────────────────────────────────────

model User {
  id                Int            @id @default(autoincrement())
  name              String
  email             String?        @unique
  phone             String         @unique
  pin               String
  transport_type    TransportType  @default(motorcycle)
  role              Role           @default(driver)
  status            UserStatus     @default(active)
  points            Int            @default(0)
  phone_verified_at DateTime?
  email_verified_at DateTime?
  password          String?
  remember_token    String?
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  wallet            Wallet?
  assignments       OrderAssignment[]

  // Auditoría obligatoria para Play Store / Compliance
  isActive          Boolean        @default(true)
  deletedAt         DateTime?      // Soporte para Soft Delete

  // Relaciones de Cumplimiento Normativo
  consents          UserConsent[]
  deviceTokens      DeviceToken[]
  accountDeletions  AccountDeletionRequest[]

  @@map("users")
}

// ─── Pedidos ──────────────────────────────────────────────────────────────────

model Order {
  id           Int               @id @default(autoincrement())
  type         String            // ej: 'delivery', 'express'
  client_name  String            @db.VarChar(100)
  pickup       String            // Dirección de recogida
  delivery     String            // Dirección de entrega
  address      String?           @db.Text
  delivery_fee Decimal           @db.Decimal(10, 2)
  urgency      Urgency           @default(baja)
  description  String?           @db.Text
  currency     String            @default("BOB") @db.VarChar(3)
  status       String            @default("pending") @db.VarChar(30)
  duration     String?           @db.VarChar(30)
  points       Int               @default(0)
  city_id      Int               @default(1)
  city         City              @relation(fields: [city_id], references: [id])
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  assignments  OrderAssignment[]

  @@map("orders")
}

// ─── Asignaciones de Pedidos ──────────────────────────────────────────────────

model OrderAssignment {
  id         Int      @id @default(autoincrement())
  order_id   Int
  user_id    Int
  status     String   @default("pending") // pending, accepted, rejected, completed
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("order_assignments")
}

// ─── Billetera ────────────────────────────────────────────────────────────────

model Wallet {
  id         Int           @id @default(autoincrement())
  user_id    Int           @unique
  balance    Decimal       @default(0.00) @db.Decimal(15, 2)
  currency   String        @default("BOB") @db.VarChar(3)
  is_active  Boolean       @default(true)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id         Int      @id @default(autoincrement())
  wallet_id  Int
  type       String   @db.VarChar(30) // deposit, withdrawal, payment, refund
  amount     Decimal  @db.Decimal(15, 2)
  reference  String?
  metadata   Json     @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  wallet     Wallet   @relation(fields: [wallet_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("transactions")
}

// ─── Zonas de Entrega ─────────────────────────────────────────────────────────

model Zone {
  id          Int      @id @default(autoincrement())
  name        String
  coordinates Json     // Array de puntos [[lat, lng], [lat, lng]...]
  extra_rate  Decimal  @default(0) @db.Decimal(8, 2)
  color       String   @default("#ff0000")
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("zones")
}

// ─── Compliance (Google Play Store) ──────────────────────────────────────────

// 1. Consentimientos explícitos del Usuario
model UserConsent {
  id              String         @id @default(uuid())
  userId          Int
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType     String         // e.g., "BACKGROUND_LOCATION", "PRIVACY_POLICY"
  isGranted       Boolean        @default(false)
  policyVersion   String
  ipAddress       String?
  grantedAt       DateTime       @default(now())
  revokedAt       DateTime?

  @@unique([userId, consentType, policyVersion])
  @@index([consentType])
  @@map("user_consents")
}

// 2. Registro de dispositivos y Tokens de Notificación
model DeviceToken {
  id            String    @id @default(uuid())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String    @unique
  deviceOs      String    // "ANDROID" o "IOS"
  osVersion     String?
  deviceModel   String?
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("device_tokens")
}

// 3. Solicitudes de Eliminación de Cuenta
model AccountDeletionRequest {
  id            String          @id @default(uuid())
  userId        Int
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason        DeletionReason
  customReason  String?         @db.Text
  status        String          @default("PENDING") // PENDING, PROCESSED, CANCELLED
  scheduledFor  DateTime
  createdAt     DateTime        @default(now())
  processedAt   DateTime?

  @@index([userId])
  @@index([status])
  @@map("account_deletion_requests")
}

// 4. Control de Versiones de Políticas Legales
model AppPolicy {
  id          String   @id @default(uuid())
  title       String
  type        String   // "TERMS", "PRIVACY", "LOCATION_DISCLOSURE"
  version     String
  content     String   @db.Text
  isActive    Boolean  @default(false)
  publishedAt DateTime @default(now())

  @@unique([type, version])
  @@map("app_policies")
}