// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin
  driver
}

enum UserStatus {
  active
  inactive
  suspended
}

model User {
  id                Int               @id @default(autoincrement())
  name              String
  email             String?           @unique
  phone             String            @unique
  pin               String
  city              String            @default("Oruro")
  role              Role              @default(driver)
  status            UserStatus        @default(active)
  points            Int               @default(0)
  phone_verified_at DateTime?
  email_verified_at DateTime?
  password          String?
  remember_token    String?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  
  wallet            Wallet?
  assignments       OrderAssignment[]

  // Auditoría obligatoria para Play Store / Compliance
  isActive          Boolean           @default(true)
  deletedAt         DateTime?         // Soporte para Soft Delete solicitado por Google

  // Relaciones de Cumplimiento Normativo
  consents          UserConsent[]
  deviceTokens      DeviceToken[]
  accountDeletions  AccountDeletionRequest[]

  @@map("users")
}

enum Urgency {
  baja
  media
  alta
}

model Order {
  id           Int               @id @default(autoincrement())
  type         String            // ej: 'delivery', 'express'
  client_name  String            @db.VarChar(100)
  pickup       String            // Dirección de recogida
  delivery     String            // Dirección de entrega
  address      String?           @db.Text
  delivery_fee Decimal           @db.Decimal(10, 2)
  urgency      Urgency           @default(baja)
  description  String?           @db.Text
  currency     String            @default("BOB") @db.VarChar(3)
  status       String            @default("pending") @db.VarChar(30)
  duration     String?           @db.VarChar(30)
  points       Int               @default(0)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  assignments  OrderAssignment[]

  @@map("orders")
}

model OrderAssignment {
  id         Int      @id @default(autoincrement())
  order_id   Int
  user_id    Int
  status     String   @default("pending") // pending, accepted, rejected, completed
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("order_assignments")
}

model Wallet {
  id         Int           @id @default(autoincrement())
  user_id    Int           @unique
  balance    Decimal       @default(0.00) @db.Decimal(15, 2)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id         Int      @id @default(autoincrement())
  wallet_id  Int
  type       String   @db.VarChar(30) // deposit, withdrawal, payment, refund
  amount     Decimal  @db.Decimal(15, 2)
  reference  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  wallet     Wallet   @relation(fields: [wallet_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("transactions")
}

model Zone {
  id          Int      @id @default(autoincrement())
  name        String
  coordinates Json     // Array de puntos [[lat, lng], [lat, lng]...]
  extra_rate  Decimal  @default(0) @db.Decimal(8, 2)
  color       String   @default("#ff0000")
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("zones")
}

enum DeletionReason {
  PRIVACY_CONCERNS
  APP_NOT_USEFUL
  TOO_MANY_NOTIFICATIONS
  TEMPORARY_ACC_CREATION
  OTHER
}

// 1. TABLA: Consentimientos explícitos del Usuario (Requerido para Background Location)
model UserConsent {
  id              String         @id @default(uuid())
  userId          Int
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType     String         // e.g., "BACKGROUND_LOCATION", "PRIVACY_POLICY", "MARKETING"
  isGranted       Boolean        @default(false)
  policyVersion   String         // Versión del documento que aceptó (e.g., "v1.2.0")
  ipAddress       String?        // Prueba de origen del consentimiento
  grantedAt       DateTime       @default(now())
  revokedAt       DateTime?

  @@unique([userId, consentType, policyVersion])
  @@index([consentType])
  @@map("user_consents")
}

// 2. TABLA: Registro de dispositivos y Tokens de Notificación (Transparencia en Seguridad de Datos)
model DeviceToken {
  id            String    @id @default(uuid())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String    @unique // FCM Token (Firebase Cloud Messaging) o similar
  deviceOs      String    // "ANDROID" o "IOS"
  osVersion     String?   // e.g., "Android 14"
  deviceModel   String?   // e.g., "Samsung S24"
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("device_tokens")
}

// 3. TABLA: Solicitudes de Eliminación de Cuenta (Google Data Deletion Policy Compliance)
model AccountDeletionRequest {
  id            String          @id @default(uuid())
  userId        Int
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason        DeletionReason
  customReason  String?         @db.Text
  status        String          @default("PENDING") // PENDING, PROCESSED, CANCELLED
  scheduledFor  DateTime        // Google permite un periodo de gracia (e.g., 15 días antes del hard delete)
  createdAt     DateTime        @default(now())
  processedAt   DateTime?

  @@index([userId])
  @@index([status])
  @@map("account_deletion_requests")
}

// 4. TABLA: Control de Versiones de Políticas Legales (Transparencia de Cara al Usuario)
model AppPolicy {
  id          String   @id @default(uuid())
  title       String   // e.g., "Términos y Condiciones", "Política de Privacidad"
  type        String   // "TERMS", "PRIVACY", "LOCATION_DISCLOSURE"
  version     String   // e.g., "v1.0.0"
  content     String   @db.Text
  isActive    Boolean  @default(false)
  publishedAt DateTime @default(now())

  @@unique([type, version])
  @@map("app_policies")
}